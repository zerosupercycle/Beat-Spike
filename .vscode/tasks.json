{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Polymarket Latency Probe",
      "type": "shell",
      "linux": {
        "command": "bash",
        "args": ["${workspaceFolder}/.vscode/scripts/run-latency-probe.sh"]
      },
      "osx": {
        "command": "bash",
        "args": ["${workspaceFolder}/.vscode/scripts/run-latency-probe.sh"]
      },
      "windows": {
        "command": "powershell.exe",
        "args": [
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder}/.vscode/scripts/run-latency-probe.ps1"
        ]
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "showReuseMessage": false,
        "close": true
      },
      "problemMatcher": []
    }
  ]
}
