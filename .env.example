# Copy to .env in project root. Loaded when the bot starts (overrides empty YAML values).

# Wallet signing (required for live CLOB orders — do not put in config/default.yaml)
BEAT_SPIKE_EXECUTION__PRIVATE_KEY=
BEAT_SPIKE_EXECUTION__FUNDER=

# CLOB L2 API (optional here if set in config/default.yaml; env overrides YAML when set)
BEAT_SPIKE_EXECUTION__API_KEY=
BEAT_SPIKE_EXECUTION__API_SECRET=
BEAT_SPIKE_EXECUTION__API_PASSPHRASE=

# Optional
# BEAT_SPIKE_BOT__MODE=paper
# BEAT_SPIKE_EXECUTION__ENABLED=true

# Chainlink Data Streams (override YAML; recommended for streams_secret)
BEAT_SPIKE_CHAINLINK__STREAMS_USER_ID=
BEAT_SPIKE_CHAINLINK__STREAMS_SECRET=
